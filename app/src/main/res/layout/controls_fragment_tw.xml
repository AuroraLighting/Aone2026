<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/controls_background">

    <!-- Brightness label -->
    <TextView
        android:id="@+id/tvBrightnessLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Brightness"
        android:textColor="#80ffffff"
        android:textSize="12sp"
        android:letterSpacing="0.15"
        android:layout_marginTop="48dp"
        android:layout_marginStart="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Brightness value -->
    <TextView
        android:id="@+id/tvLevel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="100%"
        android:textColor="#ffffff"
        android:textSize="48sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        android:layout_marginStart="32dp"
        app:layout_constraintEnd_toStartOf="@id/tvColourTemperature"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBrightnessLabel" />

    <!-- Colour temp label -->
    <TextView
        android:id="@+id/tvCTLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Colour Temp"
        android:textColor="#80ffffff"
        android:textSize="12sp"
        android:letterSpacing="0.15"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Colour temp value -->
    <TextView
        android:id="@+id/tvColourTemperature"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="2700K"
        android:textColor="#FFD080"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textAlignment="textEnd"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvLevel"
        app:layout_constraintTop_toBottomOf="@id/tvCTLabel" />

    <!-- Brightness slider card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/brightnessCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#0D2E52"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLevel">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀"
                android:textColor="#FF9500"
                android:textSize="16sp"
                android:alpha="0.4"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <SeekBar
                android:id="@+id/level_seekbar"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:maxHeight="44dp"
                android:minHeight="44dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:progress="40"
                android:progressDrawable="@drawable/level_seekbar"
                android:splitTrack="false"
                android:thumb="@android:color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvBrightMax"
                app:layout_constraintStart_toEndOf="@id/tvBrightMin"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvBrightMin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀"
                android:textColor="#FF9500"
                android:textSize="16sp"
                android:alpha="0.4"
                android:layout_marginStart="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvBrightMax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀"
                android:textColor="#FF9500"
                android:textSize="24sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Colour temp slider card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/ctCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#0D2E52"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/brightnessCard">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvCTMin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#FFD080"
                android:textSize="14sp"
                android:alpha="0.5"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <SeekBar
                android:id="@+id/colour_temperature_seekbar"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:maxHeight="44dp"
                android:minHeight="44dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:progress="40"
                android:progressDrawable="@drawable/colour_temperature_seekbar"
                android:splitTrack="false"
                android:thumb="@android:color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvCTMax"
                app:layout_constraintStart_toEndOf="@id/tvCTMin"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvCTMax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- colour layout placeholder for RGBW compat -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/colourLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/levelsLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/levelsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/colourLayout" />

</androidx.constraintlayout.widget.ConstraintLayout>
